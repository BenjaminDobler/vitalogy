# /opt/vitalogy/.env on the server. chmod 600, owned by the deploy user.
# DO NOT check this filled-in copy into git.

# --- Database (vitalogy db on the shared Postgres) ---
DATABASE_URL="postgresql://vitalogy:CHANGE_ME@localhost:5432/vitalogy?schema=public"

# --- API server ---
NODE_ENV=production
API_PORT=3001
# Lock everything behind auth in prod — no dev-user fallback.
AUTH_REQUIRED=true

# --- Auth (JWT sessions) ---
# Generate once with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME

# --- Encryption key for per-user AI keys at rest ---
# Generate once with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=CHANGE_ME

# --- Strava OAuth ---
STRAVA_CLIENT_ID=CHANGE_ME
STRAVA_CLIENT_SECRET=CHANGE_ME
# In the Strava app settings, add this exact URI to "Authorization Callback Domain"
# (Strava uses domain-only, not full URL):  vitalogy.app
STRAVA_REDIRECT_URI=https://vitalogy.app/api/auth/strava/callback

# --- Google OAuth ---
# In the Google Cloud Console OAuth client, add the redirect URI below to
# "Authorized redirect URIs".
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://vitalogy.app/api/auth/google/callback

# --- AI providers (optional; SERVER mode keys for users without their own) ---
# Leave blank to require users to bring their own Anthropic/Gemini key
# via Profile → AI keys.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
