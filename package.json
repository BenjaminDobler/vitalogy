{
  "name": "vitalogy",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "serve:web": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx serve web",
    "serve:api": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx serve api",
    "serve:mobile": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx serve mobile",
    "serve:simulator": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx serve simulator",
    "serve:all": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx run-many -t serve -p web,api",
    "build:mobile": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx build mobile",
    "cap:sync": "cd apps/mobile && npx cap sync",
    "cap:open:ios": "cd apps/mobile && npx cap open ios",
    "cap:open:android": "cd apps/mobile && npx cap open android"
  },
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
