# --- Database (docker-compose default) ---
POSTGRES_USER=cycle
POSTGRES_PASSWORD=cycle
POSTGRES_DB=cycle
POSTGRES_PORT=5432
DATABASE_URL="postgresql://cycle:cycle@localhost:5432/cycle?schema=public"

# --- API server ---
API_PORT=3000

# --- Strava OAuth ---
# Create an app at https://www.strava.com/settings/api and put the values here.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# --- AI providers (server-stored mode) ---
# Leave blank if you prefer the user-provided-key mode (keys stored encrypted in DB)
# or the export-for-AI mode (no SDK calls at all).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Encryption key for user-provided AI keys at rest ---
# 32-byte base64. Generate with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=
