// Cycle-App database schema.
// Edit this file, then run `npm run prisma:migrate -- --name <change>`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A person using the app. For now: single-user local setup is fine,
// but we model User so multi-user / shared deployments are straightforward later.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stravaAccount StravaAccount?
  activities    Activity[]
  apiKeys       ApiKey[]
  analyses      Analysis[]
  profile       UserProfile?
  memories      Memory[]
  chatThreads   ChatThread[]
  workouts      Workout[]
}

// Per-athlete profile + training settings. Canonical source of truth for
// FTP / max HR / rest HR (today's web AthleteSettingsService keeps a
// localStorage cache; consolidation comes in a follow-up phase). All
// fields nullable — users fill them in over time.
model UserProfile {
  userId        String    @id
  birthdate     DateTime?
  weightKg      Float?
  heightCm      Float?
  sportPrimary  String?   // 'Ride', 'VirtualRide', etc.
  ftpW          Int?
  maxHrBpm      Int?
  restHrBpm     Int?
  weightGoalKg  Float?
  ftpGoalW      Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Long-term facts the AI coach should remember across sessions.
// The coach reads/writes these via tool calls; the user can review and
// delete them from the Profile page (transparency).
model Memory {
  id        String         @id @default(cuid())
  userId    String
  category  MemoryCategory
  content   String         @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category, createdAt])
}

enum MemoryCategory {
  GOAL
  PREFERENCE
  FACT
  EVENT
}

// Persistent chat conversation. One thread per user for v1; the schema
// is multi-thread-ready so adding a thread switcher later is just UI.
model ChatThread {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  // Provider locked at first message — switching mid-thread would
  // require reformatting tool_use blocks across SDK shapes, which is
  // messier than just starting a fresh thread. Null until first send.
  provider  AIProvider?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, createdAt])
}

// One message in a chat thread. For tool_use and tool_result entries the
// structured payload (tool name, input JSON, output JSON) lives in
// `metadata` so the coach can rebuild full context on the next turn.
model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      ChatRole
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

enum ChatRole {
  USER
  ASSISTANT
  TOOL
}

// A planned ride with structured intervals. Most commonly created by the
// AI coach during chat ("queue an easy ride for tomorrow") but users
// could also build their own. The mobile recorder picks one up at session
// start and overlays live "are you on target?" guidance.
model Workout {
  id           String          @id @default(cuid())
  userId       String
  title        String
  description  String?
  // WorkoutInterval[] — full structure in libs/shared/data-models.
  intervals    Json
  // Cached totals so list views don't have to walk the JSON.
  totalSec     Int
  estimatedTss Int?

  status       WorkoutStatus   @default(PLANNED)
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  // Set when a recording is finished against this workout.
  activityId   String?

  // Who created it — 'COACH' from a tool-call, 'USER' from the web UI.
  createdBy    String          @default("USER")

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, scheduledFor])
}

enum WorkoutStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// Strava OAuth tokens. One per user. Refresh tokens rotate.
model StravaAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  athleteId       BigInt   @unique
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  scope           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// User-provided AI provider keys (encrypted at rest — see libs/api/ai).
// Server-stored keys (the default mode) come from env vars and are NOT stored here.
model ApiKey {
  id            String       @id @default(cuid())
  userId        String
  provider      AIProvider
  encryptedKey  String       // ciphertext; AES-256-GCM via libs/api/ai/crypto
  // Plaintext last 4 chars of the original key, shown in the UI as the
  // "...abcd" disambiguator. Not security-sensitive on its own.
  lastFour      String       @default("")
  label         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

enum AIProvider {
  ANTHROPIC
  GEMINI
}

// A single ride / workout / training session.
// `source` lets us mix Strava imports with future first-party recordings.
model Activity {
  id              String        @id @default(cuid())
  userId          String
  source          ActivitySource
  sourceId        String        // e.g. Strava activity ID; unique within a source
  name            String
  sportType       String        // Ride, VirtualRide, GravelRide, MountainBikeRide, etc.
  startTime       DateTime
  timezone        String?
  durationSec     Int           // moving time
  elapsedSec      Int           // total time including stops
  distanceM       Float
  elevationGainM  Float?
  avgSpeedMps     Float?
  maxSpeedMps     Float?
  avgWatts        Float?
  weightedAvgWatts Float?
  maxWatts        Int?
  kilojoules      Float?
  avgHeartrate    Float?
  maxHeartrate    Int?
  avgCadence      Float?
  trainerActivity Boolean       @default(false)
  commute         Boolean       @default(false)

  // Weather snapshot at session start. Filled by mobile recorder (Open-Meteo)
  // or later by a backend enricher for Strava imports.
  // windDirectionDeg follows the meteorological convention: where the wind
  // comes FROM (0=N, 90=E, 180=S, 270=W).
  tempC               Float?
  apparentTempC       Float?
  humidityPct         Float?
  windSpeedKmh        Float?
  windDirectionDeg    Float?
  windGustKmh         Float?
  precipMm            Float?
  weatherCode         Int?         // WMO code (0=clear, 95=thunderstorm, etc.)
  weatherSource       String?      // e.g. 'open-meteo:current'
  weatherObservedAt   DateTime?

  raw             Json?         // full source payload for re-processing later

  // Strava export tracking. When a MANUAL / FIT / TCX / GPX activity is
  // pushed to Strava via POST /uploads, we store the resulting upload id,
  // the final strava activity id, and a timestamp. Re-export is a no-op
  // once stravaActivityId is set.
  stravaExportId      String?
  stravaActivityId    String?
  stravaExportedAt    DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  streams Stream[]
  laps    Lap[]
  analyses Analysis[]

  @@unique([source, sourceId])
  @@index([userId, startTime])
}

enum ActivitySource {
  STRAVA
  MANUAL
  FIT_FILE
  TCX_FILE
  GPX_FILE
}

// Time-series streams for an activity (power, hr, cadence, altitude, latlng, ...).
// Stored as JSON for now to keep things simple; revisit if we need per-sample queries.
model Stream {
  id         String   @id @default(cuid())
  activityId String
  type       String   // 'watts' | 'heartrate' | 'cadence' | 'altitude' | 'latlng' | 'time' | 'distance' | 'velocity_smooth'
  resolution String   @default("high") // 'low' | 'medium' | 'high'
  data       Json     // number[] or [lat, lng][] etc.

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, type, resolution])
}

// Strava-style laps. Optional.
model Lap {
  id              String   @id @default(cuid())
  activityId      String
  lapIndex        Int
  name            String?
  startTime       DateTime
  durationSec     Int
  distanceM       Float
  avgWatts        Float?
  avgHeartrate    Float?
  avgSpeedMps     Float?
  elevationGainM  Float?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, lapIndex])
}

// One AI-generated analysis run. Stores the prompt and the model response
// so the user can revisit conclusions without re-billing the API call.
model Analysis {
  id           String        @id @default(cuid())
  userId       String
  activityId   String?       // null for multi-activity / period analyses
  provider     AIProvider
  model        String        // e.g. 'claude-opus-4-7', 'gemini-2.5-pro'
  prompt       String
  response     String
  inputTokens  Int?
  outputTokens Int?
  costUsd      Decimal?      @db.Decimal(10, 4)
  createdAt    DateTime      @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
