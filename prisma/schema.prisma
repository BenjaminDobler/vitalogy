// Cycle-App database schema.
// Edit this file, then run `npm run prisma:migrate -- --name <change>`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A person using the app. For now: single-user local setup is fine,
// but we model User so multi-user / shared deployments are straightforward later.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stravaAccount StravaAccount?
  activities    Activity[]
  apiKeys       ApiKey[]
  analyses      Analysis[]
}

// Strava OAuth tokens. One per user. Refresh tokens rotate.
model StravaAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  athleteId       BigInt   @unique
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  scope           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// User-provided AI provider keys (encrypted at rest — see libs/api/ai).
// Server-stored keys (the default mode) come from env vars and are NOT stored here.
model ApiKey {
  id            String       @id @default(cuid())
  userId        String
  provider      AIProvider
  encryptedKey  String       // ciphertext; key derivation in libs/api/ai
  label         String?
  createdAt     DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

enum AIProvider {
  ANTHROPIC
  GEMINI
}

// A single ride / workout / training session.
// `source` lets us mix Strava imports with future first-party recordings.
model Activity {
  id              String        @id @default(cuid())
  userId          String
  source          ActivitySource
  sourceId        String        // e.g. Strava activity ID; unique within a source
  name            String
  sportType       String        // Ride, VirtualRide, GravelRide, MountainBikeRide, etc.
  startTime       DateTime
  timezone        String?
  durationSec     Int           // moving time
  elapsedSec      Int           // total time including stops
  distanceM       Float
  elevationGainM  Float?
  avgSpeedMps     Float?
  maxSpeedMps     Float?
  avgWatts        Float?
  weightedAvgWatts Float?
  maxWatts        Int?
  kilojoules      Float?
  avgHeartrate    Float?
  maxHeartrate    Int?
  avgCadence      Float?
  trainerActivity Boolean       @default(false)
  commute         Boolean       @default(false)

  // Weather snapshot at session start. Filled by mobile recorder (Open-Meteo)
  // or later by a backend enricher for Strava imports.
  // windDirectionDeg follows the meteorological convention: where the wind
  // comes FROM (0=N, 90=E, 180=S, 270=W).
  tempC               Float?
  apparentTempC       Float?
  humidityPct         Float?
  windSpeedKmh        Float?
  windDirectionDeg    Float?
  windGustKmh         Float?
  precipMm            Float?
  weatherCode         Int?         // WMO code (0=clear, 95=thunderstorm, etc.)
  weatherSource       String?      // e.g. 'open-meteo:current'
  weatherObservedAt   DateTime?

  raw             Json?         // full source payload for re-processing later

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  streams Stream[]
  laps    Lap[]
  analyses Analysis[]

  @@unique([source, sourceId])
  @@index([userId, startTime])
}

enum ActivitySource {
  STRAVA
  MANUAL
  FIT_FILE
  TCX_FILE
  GPX_FILE
}

// Time-series streams for an activity (power, hr, cadence, altitude, latlng, ...).
// Stored as JSON for now to keep things simple; revisit if we need per-sample queries.
model Stream {
  id         String   @id @default(cuid())
  activityId String
  type       String   // 'watts' | 'heartrate' | 'cadence' | 'altitude' | 'latlng' | 'time' | 'distance' | 'velocity_smooth'
  resolution String   @default("high") // 'low' | 'medium' | 'high'
  data       Json     // number[] or [lat, lng][] etc.

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, type, resolution])
}

// Strava-style laps. Optional.
model Lap {
  id              String   @id @default(cuid())
  activityId      String
  lapIndex        Int
  name            String?
  startTime       DateTime
  durationSec     Int
  distanceM       Float
  avgWatts        Float?
  avgHeartrate    Float?
  avgSpeedMps     Float?
  elevationGainM  Float?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, lapIndex])
}

// One AI-generated analysis run. Stores the prompt and the model response
// so the user can revisit conclusions without re-billing the API call.
model Analysis {
  id           String        @id @default(cuid())
  userId       String
  activityId   String?       // null for multi-activity / period analyses
  provider     AIProvider
  model        String        // e.g. 'claude-opus-4-7', 'gemini-2.5-pro'
  prompt       String
  response     String
  inputTokens  Int?
  outputTokens Int?
  costUsd      Decimal?      @db.Decimal(10, 4)
  createdAt    DateTime      @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
