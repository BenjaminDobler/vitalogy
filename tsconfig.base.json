{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["vitalogy"],
    "paths": {
      "feature-activities": ["./libs/web/feature-activities/src/index.ts"],
      "feature-import": ["./libs/web/feature-import/src/index.ts"],
      "feature-analysis": ["./libs/web/feature-analysis/src/index.ts"],
      "ui": ["./libs/web/ui/src/index.ts"]
    }
  }
}
