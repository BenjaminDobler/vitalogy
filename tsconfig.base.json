{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["vitalogy"],
    "paths": {
      "feature-activities": ["./libs/web/feature-activities/src/index.ts"],
      "feature-import": ["./libs/web/feature-import/src/index.ts"],
      "feature-analysis": ["./libs/web/feature-analysis/src/index.ts"],
      "feature-profile": ["./libs/web/feature-profile/src/index.ts"],
      "feature-coach": ["./libs/web/feature-coach/src/index.ts"],
      "feature-workouts": ["./libs/web/feature-workouts/src/index.ts"],
      "feature-auth": ["./libs/web/feature-auth/src/index.ts"],
      "training-metrics": ["./libs/shared/training-metrics/src/index.ts"],
      "ui": ["./libs/web/ui/src/index.ts"],
      "ble": ["./libs/mobile/ble/src/index.ts"],
      "recording": ["./libs/mobile/recording/src/index.ts"],
      "feature-record": ["./libs/mobile/feature-record/src/index.ts"],
      "api-client": ["./libs/mobile/api-client/src/index.ts"],
      "feature-settings": ["./libs/mobile/feature-settings/src/index.ts"],
      "weather": ["./libs/mobile/weather/src/index.ts"],
      "dev-sim": ["./libs/mobile/dev-sim/src/index.ts"],
      "feature-history": ["./libs/mobile/feature-history/src/index.ts"]
    }
  }
}
